# Credentials example shipped with every new project.
#
# credentials.py copies this to ~/.config/<project_name>.env on first run
# (chmod 600). Real values live in that copied target, never in this tracked
# file. This .example file stays in the repo as a reference for the keys the
# project expects; re-running apply.py is a no-op once the target exists.

# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=
# DB_PASSWORD=
# API_KEY=
